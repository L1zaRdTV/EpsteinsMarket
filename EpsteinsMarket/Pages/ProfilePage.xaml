<Page x:Class="EpsteinMarket.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProfilePage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="{StaticResource ClassicTitleBrush}" LastChildFill="False" Margin="0,0,0,10">
            <TextBlock Text="Профиль пользователя" Style="{StaticResource PageHeaderTextStyle}" Margin="16,12" DockPanel.Dock="Left"/>
            <Button x:Name="btnBack" Content="Назад" Click="btnBack_Click" DockPanel.Dock="Right" Margin="8"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="12,0,12,10">
            <StackPanel>
                <TextBlock x:Name="tbFullName" Text="Имя:" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="tbLogin" Text="Логин:" Margin="0,10,0,0" FontSize="16"/>
                <TextBlock x:Name="tbEmail" Text="Email:" Margin="0,10,0,0" FontSize="16"/>
                <TextBlock x:Name="tbPhone" Text="Телефон:" Margin="0,10,0,0" FontSize="16"/>
                <TextBlock x:Name="tbCreatedAt" Text="Дата регистрации:" Margin="0,10,0,0" FontSize="16"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="12,0,12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="История заказов" FontSize="22" FontWeight="Bold" Margin="0,0,0,6"/>
            <ListView x:Name="lvOrders" Grid.Row="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding OrderID, StringFormat=Заказ #{0}}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding OrderDate, StringFormat=Дата: {0}}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding TotalAmount, StringFormat=Сумма: {0} ₽}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding OrderStatuses.StatusName}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="3" Margin="12,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Чеки" FontSize="22" FontWeight="Bold" Margin="0,0,0,6"/>
            <ListView x:Name="lvReceipts" Grid.Row="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding ReceiptID, StringFormat=Чек #{0}}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat=Дата: {0}}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding PdfPath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                <Button Grid.Column="3"
                                        Content="Открыть"
                                        Width="90"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Tag="{Binding}"
                                        Click="btnOpenReceipt_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
