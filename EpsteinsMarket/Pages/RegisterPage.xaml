<Page x:Class="EpsteinMarket.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:EpsteinMarket.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Title="RegisterPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Style="{StaticResource CardBorderStyle}"
                    Width="460"
                    MaxWidth="460"
                    HorizontalAlignment="Center"
                    Margin="16"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="ФИО:"/>
                    <TextBox x:Name="txtName" MaxLength="70"/>
                    <TextBlock Text="Логин:"/>
                    <TextBox x:Name="txtLogin" MaxLength="50"/>
                    <TextBlock Text="Пароль:"/>
                    <PasswordBox x:Name="txtPassword" MaxLength="50"/>
                    <TextBlock Text="Повторите пароль:"/>
                    <PasswordBox x:Name="txtPasswordRepeat" MaxLength="50"/>
                    <TextBlock Text="Электронная почта:"/>
                    <TextBox x:Name="txtEmail" MaxLength="50"/>
                    <TextBlock Text="Номер телефона:"/>
                    <TextBox x:Name="txtPhone" MaxLength="30"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button x:Name="btnBack" Content="Назад" Width="150" Click="btnBack_Click"/>
                        <Button x:Name="btnRegister" Content="Зарегистрироваться" Width="180" Click="btnRegister_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
