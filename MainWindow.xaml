<Window x:Class="EpsteinsMarket.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Epsteins Market"
        Height="760"
        Width="1240"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Border Style="{StaticResource CardBorderStyle}" Padding="0" CornerRadius="20" Background="#FDFDFF">
            <Frame x:Name="frmMain" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
