<Window x:Class="EpsteinsMarket.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Epsteins Market"
        Height="820"
        Width="1380"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Border Style="{StaticResource CardBorderStyle}" Padding="0" CornerRadius="24" Background="#FAFCFB">
            <Frame x:Name="frmMain" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
