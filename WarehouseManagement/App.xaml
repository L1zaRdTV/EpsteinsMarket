<Application x:Class="WarehouseManagement.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="IndustrialBg">#0B1320</Color>
        <Color x:Key="IndustrialPanel">#142033</Color>
        <Color x:Key="IndustrialPanelAlt">#1E2F49</Color>
        <Color x:Key="IndustrialBorder">#38506F</Color>
        <Color x:Key="IndustrialAccent">#F59E0B</Color>
        <Color x:Key="IndustrialAccentDark">#B45309</Color>
        <Color x:Key="IndustrialText">#E5EEF9</Color>
        <Color x:Key="IndustrialMuted">#9FB1C8</Color>
        <Color x:Key="IndustrialInput">#F8FAFC</Color>

        <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource IndustrialBg}"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource IndustrialPanel}"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource IndustrialBorder}"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource IndustrialText}"/>
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="{StaticResource IndustrialAccent}"/>
        <SolidColorBrush x:Key="ClassicTitleBrush" Color="{StaticResource IndustrialPanelAlt}"/>
        <SolidColorBrush x:Key="ClassicTitleTextBrush" Color="{StaticResource IndustrialText}"/>
        <SolidColorBrush x:Key="ClassicFaceBrush" Color="{StaticResource IndustrialPanel}"/>
        <SolidColorBrush x:Key="ClassicWindowBrush" Color="{StaticResource IndustrialInput}"/>
        <SolidColorBrush x:Key="ClassicDarkBrush" Color="{StaticResource IndustrialBorder}"/>
        <SolidColorBrush x:Key="ClassicLightBrush" Color="#5B789D"/>
        <SolidColorBrush x:Key="ClassicShadowBrush" Color="#07101D"/>
        <SolidColorBrush x:Key="IndustrialMutedBrush" Color="{StaticResource IndustrialMuted}"/>

        <Style TargetType="Page">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="{StaticResource ClassicFaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#29405F"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryButtonBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#FBBF24"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,4,0,10"/><Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="{StaticResource ClassicWindowBrush}"/><Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/><Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,4,0,10"/><Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="{StaticResource ClassicWindowBrush}"/><Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/><Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox"><Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,4,0,10"/><Setter Property="Background" Value="{StaticResource ClassicWindowBrush}"/><Setter Property="Foreground" Value="#111827"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/></Style>
        <Style TargetType="ListView"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource AccentTextBrush}"/><Setter Property="BorderThickness" Value="0"/></Style>
        <Style TargetType="ListBox"><Setter Property="Background" Value="{StaticResource ClassicWindowBrush}"/><Setter Property="Foreground" Value="#111827"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/></Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="10"/><Setter Property="Padding" Value="16"/><Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="PageHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="25"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{StaticResource ClassicTitleTextBrush}"/><Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="WindowHeaderBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ClassicTitleBrush}"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/><Setter Property="BorderThickness" Value="0,0,0,1"/><Setter Property="Padding" Value="18,10"/>
        </Style>
    </Application.Resources>
</Application>
