<Page x:Class="EpsteinsMarket.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PageTask">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="tbSearch" Width="220" Margin="0,0,10,0" TextChanged="tbSearch_TextChanged" />
            <ComboBox x:Name="cbCategory" Width="220" Margin="0,0,10,0" SelectionChanged="cbCategory_SelectionChanged" DisplayMemberPath="Name" />
            <ComboBox x:Name="cbSort" Width="220" Margin="0,0,10,0" SelectionChanged="cbSort_SelectionChanged">
                <ComboBoxItem Content="По умолчанию" Tag="default" IsSelected="True"/>
                <ComboBoxItem Content="Цена по возрастанию" Tag="price_asc"/>
                <ComboBoxItem Content="Цена по убыванию" Tag="price_desc"/>
                <ComboBoxItem Content="Сначала новые" Tag="new"/>
            </ComboBox>
            <Button Content="Список" Width="100" Margin="0,0,5,0" Click="btnList_Click"/>
            <Button Content="Плитка" Width="100" Margin="0,0,5,0" Click="btnTile_Click"/>
            <Button Content="Добавить товар" Width="130" Click="btnAdd_Click"/>
        </StackPanel>

        <TextBlock x:Name="tbCounter" Grid.Row="1" Margin="0,10,0,10" FontWeight="SemiBold"/>

        <Grid Grid.Row="2">
            <ListView x:Name="lvProducts" Visibility="Visible" SelectionChanged="lvProducts_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Name}" Width="250"/>
                        <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="350"/>
                        <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <ItemsControl x:Name="icProducts" Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6" Padding="8" BorderBrush="Gray" BorderThickness="1" Width="230">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Price}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="В избранное" Click="btnFavorite_Click" Tag="{Binding ID}" Margin="0,0,5,0"/>
                                    <Button Content="Изменить" Click="btnEdit_Click" Tag="{Binding ID}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Page>
