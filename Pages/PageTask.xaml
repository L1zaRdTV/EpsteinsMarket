<Page x:Class="EpsteinsMarket.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PageTask">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Каталог товаров" FontSize="30" FontWeight="Bold"/>
                        <TextBlock Text="Поиск, фильтрация и управление карточками в одном месте."
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Добавить товар" Width="150" Height="40" VerticalAlignment="Center" Click="btnAdd_Click"/>
                </Grid>

                <WrapPanel Grid.Row="1" Margin="0,16,0,0" ItemHeight="40">
                    <TextBox x:Name="tbSearch" Width="260" Margin="0,0,10,8" TextChanged="tbSearch_TextChanged"/>
                    <ComboBox x:Name="cbCategory" Width="220" Margin="0,0,10,8" SelectionChanged="cbCategory_SelectionChanged" DisplayMemberPath="Name"/>
                    <ComboBox x:Name="cbSort" Width="220" Margin="0,0,10,8" SelectionChanged="cbSort_SelectionChanged">
                        <ComboBoxItem Content="По умолчанию" Tag="default" IsSelected="True"/>
                        <ComboBoxItem Content="Цена по возрастанию" Tag="price_asc"/>
                        <ComboBoxItem Content="Цена по убыванию" Tag="price_desc"/>
                        <ComboBoxItem Content="Сначала новые" Tag="new"/>
                    </ComboBox>
                    <Button Content="Список" Width="100" Margin="0,0,8,8" Click="btnList_Click" Style="{StaticResource GhostButtonStyle}"/>
                    <Button Content="Плитка" Width="100" Margin="0,0,8,8" Click="btnTile_Click" Style="{StaticResource GhostButtonStyle}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Padding="12,8" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CBD5FF" BorderThickness="1">
            <TextBlock x:Name="tbCounter" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentDark}"/>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="10">
            <Grid>
                <ListView x:Name="lvProducts" Visibility="Visible" SelectionChanged="lvProducts_SelectionChanged" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Name}" Width="240"/>
                            <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="430"/>
                            <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price}" Width="140"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="icProducts" Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8" Padding="12" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Width="250" Background="{StaticResource SurfaceSoft}">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" FontSize="16" Text="{Binding Name}"/>
                                        <TextBlock Text="{Binding Description}" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
                                        <Border Margin="0,8,0,0" Padding="8,4" HorizontalAlignment="Left" Background="#E0E7FF" CornerRadius="8">
                                            <TextBlock Text="{Binding Price}" FontWeight="SemiBold" Foreground="{StaticResource AccentDark}"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="В избранное" Click="btnFavorite_Click" Tag="{Binding ID}" Margin="0,0,5,0"/>
                                            <Button Content="Изменить" Click="btnEdit_Click" Tag="{Binding ID}" Style="{StaticResource GhostButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
