<Page x:Class="EpsteinsMarket.Pages.AddRecip"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddRecip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbTitle" FontSize="26" FontWeight="Bold"/>

        <TextBox Grid.Row="1" Margin="0,10,0,0" Height="30" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        <TextBox Grid.Row="2" Margin="0,10,0,0" Height="90" AcceptsReturn="True" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBox Grid.Row="3" Margin="0,10,0,0" Height="30" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" />
        <ComboBox x:Name="cbCategory" Grid.Row="4" Margin="0,10,0,0" Height="30" DisplayMemberPath="Name" SelectionChanged="cbCategory_SelectionChanged" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Загрузить изображение" Width="170" Click="btnLoadImage_Click"/>
            <Button Content="◀" Width="40" Margin="10,0,0,0" Click="btnPrevImage_Click"/>
            <Button Content="▶" Width="40" Margin="5,0,0,0" Click="btnNextImage_Click"/>
        </StackPanel>

        <Image x:Name="imgProduct" Grid.Row="6" Height="180" Stretch="Uniform" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="140" Click="btnSave_Click"/>
            <Button Content="Назад" Width="140" Margin="10,0,0,0" Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Page>
