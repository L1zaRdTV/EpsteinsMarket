<Page x:Class="EpsteinsMarket.Pages.AddRecip"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddRecip">
    <Grid>
        <Rectangle Fill="{StaticResource StripeOverlayBrush}" Opacity="0.2"/>
        <Grid Margin="20" HorizontalAlignment="Center" MaxWidth="760">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="tbTitle" FontSize="30" FontWeight="Bold" Foreground="#0A4A7E"/>

                    <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="2" Margin="0,10,0,0" Height="96" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Grid.Row="3" Margin="0,10,0,0" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox x:Name="cbCategory" Grid.Row="4" Margin="0,10,0,0" DisplayMemberPath="Name" SelectionChanged="cbCategory_SelectionChanged" />

                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Загрузить изображение" Width="190" Click="btnLoadImage_Click"/>
                        <Button Content="◀" Width="40" Margin="10,0,0,0" Click="btnPrevImage_Click"/>
                        <Button Content="▶" Width="40" Margin="5,0,0,0" Click="btnNextImage_Click"/>
                    </StackPanel>

                    <Border Grid.Row="6" Margin="0,10,0,0" Background="#E6F5FF" CornerRadius="12" Padding="8">
                        <Image x:Name="imgProduct" Height="210" Stretch="Uniform"/>
                    </Border>

                    <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Сохранить" Width="140" Click="btnSave_Click"/>
                        <Button Content="Назад" Width="140" Margin="10,0,0,0" Click="btnBack_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
