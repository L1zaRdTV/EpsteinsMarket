<Page x:Class="EpsteinsMarket.Pages.AddRecip"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddRecip">
    <Grid Margin="24">
        <Border Style="{StaticResource CardBorderStyle}" HorizontalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*" MinWidth="390"/>
                    <ColumnDefinition Width="1*" MinWidth="310"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.ColumnSpan="2">
                    <TextBlock x:Name="tbTitle" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="Заполните карточку товара и добавьте изображения." Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,18,14,0">
                    <TextBlock Text="Название" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Описание" Margin="0,12,0,4"/>
                    <TextBox Height="130" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Цена" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Категория" Margin="0,12,0,4"/>
                    <ComboBox x:Name="cbCategory" DisplayMemberPath="Name" SelectionChanged="cbCategory_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="14,18,0,0">
                    <Border Background="#F2F7F4" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="10">
                        <Image x:Name="imgProduct" Height="290" Stretch="Uniform"/>
                    </Border>

                    <WrapPanel Margin="0,12,0,0" ItemHeight="42">
                        <Button Content="Загрузить изображение" MinWidth="205" Height="42" Click="btnLoadImage_Click" Margin="0,0,10,10"/>
                        <Button Content="◀" Width="48" Height="42" Margin="0,0,6,10" Click="btnPrevImage_Click" Style="{StaticResource GhostButtonStyle}"/>
                        <Button Content="▶" Width="48" Height="42" Margin="0,0,0,10" Click="btnNextImage_Click" Style="{StaticResource GhostButtonStyle}"/>
                    </WrapPanel>
                </StackPanel>

                <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,20,0,0">
                    <Button Content="Сохранить" MinWidth="170" Height="42" Margin="0,0,10,0" Click="btnSave_Click"/>
                    <Button Content="Назад" MinWidth="140" Height="42" Click="btnBack_Click" Style="{StaticResource GhostButtonStyle}"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
