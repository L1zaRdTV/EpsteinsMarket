<Page x:Class="EpsteinsMarket.Pages.AddRecip"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddRecip">
    <Grid Margin="20">
        <Border Style="{StaticResource CardBorderStyle}" MaxWidth="920" HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.ColumnSpan="2">
                    <TextBlock x:Name="tbTitle" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="Заполните данные товара и загрузите изображения." Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,16,12,0">
                    <TextBlock Text="Название" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Описание" Margin="0,12,0,4"/>
                    <TextBox Height="112" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Цена" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Категория" Margin="0,12,0,4"/>
                    <ComboBox x:Name="cbCategory" DisplayMemberPath="Name" SelectionChanged="cbCategory_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Grid.RowSpan="4" Margin="12,16,0,0">
                    <Border Background="#F8FAFF" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="10">
                        <Image x:Name="imgProduct" Height="270" Stretch="Uniform"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Загрузить изображение" Width="190" Click="btnLoadImage_Click"/>
                        <Button Content="◀" Width="46" Margin="10,0,0,0" Click="btnPrevImage_Click" Style="{StaticResource GhostButtonStyle}"/>
                        <Button Content="▶" Width="46" Margin="6,0,0,0" Click="btnNextImage_Click" Style="{StaticResource GhostButtonStyle}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="Сохранить" Width="160" Height="40" Click="btnSave_Click"/>
                    <Button Content="Назад" Width="140" Height="40" Margin="10,0,0,0" Click="btnBack_Click" Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
