<Page x:Class="EpsteinsMarket.Pages.Auth"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Auth">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Авторизация" FontSize="26" FontWeight="Bold"/>

        <TextBox x:Name="tbLogin" Grid.Row="1" Margin="0,10,0,0" Height="30" TextChanged="tbLogin_TextChanged"/>
        <PasswordBox x:Name="pbPassword" Grid.Row="2" Margin="0,10,0,0" Height="30" PasswordChanged="pbPassword_PasswordChanged"/>

        <Button x:Name="btnLogin" Grid.Row="3" Margin="0,10,0,0" Height="35" Content="Войти" Click="btnLogin_Click"/>
        <Button x:Name="btnReg" Grid.Row="4" Margin="0,10,0,0" Height="35" Content="Регистрация" Click="btnReg_Click"/>

        <TextBlock x:Name="tbStatus" Grid.Row="5" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Page>
