<Page x:Class="EpsteinsMarket.Pages.Auth"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Auth">
    <Grid Margin="26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="0,0,18,0" Style="{StaticResource CardBorderStyle}" Background="#EEF2FF" BorderBrush="#C7D2FE">
            <StackPanel VerticalAlignment="Center" Margin="6">
                <TextBlock Text="Epsteins Market" FontSize="42" FontWeight="Bold" Foreground="{StaticResource AccentDark}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" VerticalAlignment="Center" MaxWidth="430">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Вход в систему" FontSize="30" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Margin="0,14,0,0" Text="Логин" FontWeight="SemiBold"/>
                <TextBox x:Name="tbLogin" Grid.Row="2" Margin="0,6,0,0" TextChanged="tbLogin_TextChanged"/>
                <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="Пароль" FontWeight="SemiBold"/>
                <PasswordBox x:Name="pbPassword" Grid.Row="4" Margin="0,6,0,0" PasswordChanged="pbPassword_PasswordChanged"/>

                <StackPanel Grid.Row="5" Margin="0,18,0,0">
                    <Button x:Name="btnLogin" Height="40" Content="Войти" Click="btnLogin_Click"/>
                    <Button x:Name="btnReg" Margin="0,10,0,0" Height="40" Content="Регистрация" Style="{StaticResource GhostButtonStyle}" Click="btnReg_Click"/>
                    <TextBlock x:Name="tbStatus" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#B91C1C"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
