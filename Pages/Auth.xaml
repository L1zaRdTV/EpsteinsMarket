<Page x:Class="EpsteinsMarket.Pages.Auth"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Auth">
    <Grid>
        <Rectangle Fill="{StaticResource StripeOverlayBrush}" Opacity="0.3"/>
        <Grid Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                <TextBlock Text="🌴 Epsteins Market" FontSize="40" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Margin="0,14,0,0"
                           Text="Сине-белая тропическая атмосфера: пляж, остров и свежий бриз покупок."
                           FontSize="20"
                           TextWrapping="Wrap"
                           Foreground="#EEFFFFFF"/>
                <TextBlock Margin="0,24,0,0" Text="🏝️  ☀️  🌊" FontSize="46"/>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" MaxWidth="420" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Авторизация" FontSize="30" FontWeight="Bold" Foreground="#0B4D84"/>
                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Логин"/>
                    <TextBox x:Name="tbLogin" Grid.Row="2" Margin="0,6,0,0" TextChanged="tbLogin_TextChanged"/>
                    <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="Пароль"/>
                    <PasswordBox x:Name="pbPassword" Grid.Row="4" Margin="0,6,0,0" PasswordChanged="pbPassword_PasswordChanged"/>

                    <StackPanel Grid.Row="5" Margin="0,18,0,0">
                        <Button x:Name="btnLogin" Height="38" Content="Войти" Click="btnLogin_Click"/>
                        <Button x:Name="btnReg" Margin="0,8,0,0" Height="38" Content="Регистрация" Click="btnReg_Click"/>
                        <TextBlock x:Name="tbStatus" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#0B4D84"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
