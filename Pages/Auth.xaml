<Page x:Class="EpsteinsMarket.Pages.Auth"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Auth">
    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*" MinWidth="380"/>
            <ColumnDefinition Width="1*" MinWidth="360"/>
        </Grid.ColumnDefinitions>

        <Border Margin="0,0,20,0" Style="{StaticResource CardBorderStyle}" Background="#EAF1ED" BorderBrush="#CCDAD2">
            <Grid>
                <StackPanel VerticalAlignment="Center" MaxWidth="520">
                    <TextBlock Text="Epsteins Market" FontSize="44" FontWeight="Bold" Foreground="{StaticResource AccentDark}"/>
                    <TextBlock Margin="0,16,0,0"
                               FontSize="17"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}"
                               Text="Биржа маленьких гномиков: покупай, продавай и находи самых редких в пару кликов!"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" VerticalAlignment="Center" MaxWidth="500" MinWidth="340" HorizontalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Вход в систему" FontSize="32" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="Логин" FontWeight="SemiBold"/>
                <TextBox x:Name="tbLogin" Grid.Row="2" Margin="0,6,0,0" TextChanged="tbLogin_TextChanged"/>
                <TextBlock Grid.Row="3" Margin="0,14,0,0" Text="Пароль" FontWeight="SemiBold"/>
                <PasswordBox x:Name="pbPassword" Grid.Row="4" Margin="0,6,0,0" PasswordChanged="pbPassword_PasswordChanged"/>

                <StackPanel Grid.Row="5" Margin="0,20,0,0">
                    <Button x:Name="btnLogin" Height="42" Content="Войти" Click="btnLogin_Click"/>
                    <Button x:Name="btnReg" Margin="0,10,0,0" Height="42" Content="Регистрация" Style="{StaticResource GhostButtonStyle}" Click="btnReg_Click"/>
                    <TextBlock x:Name="tbStatus" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#B91C1C"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
