<Page x:Class="EpsteinsMarket.Pages.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reg">
    <Grid>
        <Rectangle Fill="{StaticResource StripeOverlayBrush}" Opacity="0.32"/>

        <Border VerticalAlignment="Top" Height="110" Margin="0,0,0,-42" Background="{StaticResource AccentWaveBrush}" Opacity="0.85" CornerRadius="0,0,46,46"/>

        <ScrollViewer>
            <Grid Margin="22" HorizontalAlignment="Center" MaxWidth="680">
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="🏖️ Регистрация в Beach Club"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="#084A7E" />

                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock Text="ФИО" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <TextBox x:Name="tbUserName" Margin="0,0,0,10" TextChanged="AnyField_TextChanged" ToolTip="Введите имя и фамилию" />

                            <TextBlock Text="Дата рождения" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpBirthDate" Margin="0,0,0,10" SelectedDateChanged="dpBirthDate_SelectedDateChanged" ToolTip="Выберите дату рождения" />

                            <TextBlock Text="Опыт работы (лет)" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <TextBox x:Name="tbExperience" Margin="0,0,0,10" TextChanged="AnyField_TextChanged" ToolTip="Например: 3" />

                            <TextBlock Text="Логин" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <TextBox x:Name="tbLogin" Margin="0,0,0,10" TextChanged="tbLogin_TextChanged" ToolTip="Введите логин" />

                            <TextBlock Text="Пароль" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="pbPassword" Margin="0,0,0,10" PasswordChanged="PasswordChanged" ToolTip="Введите пароль" />

                            <TextBlock Text="Подтверждение пароля" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="pbConfirmPassword" Margin="0,0,0,10" PasswordChanged="PasswordChanged" ToolTip="Повторите пароль" />

                            <TextBlock Text="Email" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <TextBox x:Name="tbEmail" Margin="0,0,0,10" TextChanged="AnyField_TextChanged" ToolTip="Например: user@mail.com" />

                            <TextBlock Text="Телефон" Foreground="#0A4C81" Margin="0,0,0,4"/>
                            <TextBox x:Name="tbPhone" Margin="0,0,0,12" TextChanged="AnyField_TextChanged" ToolTip="Например: +7 (900) 123-45-67" />

                            <Button x:Name="btnRegister" Margin="0,0,0,8" Height="38" Content="Зарегистрироваться" Click="btnRegister_Click" IsEnabled="False" />
                            <Button x:Name="btnBack" Margin="0,0,0,0" Height="38" Background="#157BC8" Content="Назад" Click="btnBack_Click" />

                            <TextBlock x:Name="tbStatus" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#0A4C81" />
                            <TextBlock x:Name="tbLoginHint" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#0A4C81" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
