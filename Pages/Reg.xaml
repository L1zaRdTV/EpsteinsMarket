<Page x:Class="EpsteinsMarket.Pages.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reg">
    <Grid>
        <ScrollViewer>
            <Grid Margin="20" HorizontalAlignment="Center" MaxWidth="680">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Регистрация" FontSize="30" FontWeight="Bold" />

                        <TextBlock Text="ФИО" Margin="0,14,0,4"/>
                        <TextBox x:Name="tbUserName" TextChanged="AnyField_TextChanged" />

                        <TextBlock Text="Дата рождения" Margin="0,10,0,4"/>
                        <DatePicker x:Name="dpBirthDate" SelectedDateChanged="dpBirthDate_SelectedDateChanged" />

                        <TextBlock Text="Опыт работы (лет)" Margin="0,10,0,4"/>
                        <TextBox x:Name="tbExperience" TextChanged="AnyField_TextChanged" />

                        <TextBlock Text="Логин" Margin="0,10,0,4"/>
                        <TextBox x:Name="tbLogin" TextChanged="tbLogin_TextChanged" />

                        <TextBlock Text="Пароль" Margin="0,10,0,4"/>
                        <PasswordBox x:Name="pbPassword" PasswordChanged="PasswordChanged" />

                        <TextBlock Text="Подтверждение пароля" Margin="0,10,0,4"/>
                        <PasswordBox x:Name="pbConfirmPassword" PasswordChanged="PasswordChanged" />

                        <TextBlock Text="Email" Margin="0,10,0,4"/>
                        <TextBox x:Name="tbEmail" TextChanged="AnyField_TextChanged" />

                        <TextBlock Text="Телефон" Margin="0,10,0,4"/>
                        <TextBox x:Name="tbPhone" TextChanged="AnyField_TextChanged" />

                        <Button x:Name="btnRegister" Margin="0,16,0,8" Height="36" Content="Зарегистрироваться" Click="btnRegister_Click" IsEnabled="False" />
                        <Button x:Name="btnBack" Height="36" Background="#374151" Content="Назад" Click="btnBack_Click" />

                        <TextBlock x:Name="tbStatus" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#B91C1C" />
                        <TextBlock x:Name="tbLoginHint" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
