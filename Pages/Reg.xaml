<Page x:Class="EpsteinsMarket.Pages.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reg">
    <Grid>
        <Rectangle Fill="{StaticResource StripeOverlayBrush}" Opacity="0.32"/>

        <Border VerticalAlignment="Top" Height="110" Margin="0,0,0,-42" Background="{StaticResource AccentWaveBrush}" Opacity="0.85" CornerRadius="0,0,46,46"/>

        <ScrollViewer>
            <Grid Margin="22" HorizontalAlignment="Center" MaxWidth="680">
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="🏖️ Регистрация в Beach Club"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="#084A7E" />

                        <TextBox x:Name="tbUserName" Grid.Row="1" Margin="0,10,0,0" TextChanged="AnyField_TextChanged" />
                        <DatePicker x:Name="dpBirthDate" Grid.Row="2" Margin="0,10,0,0" SelectedDateChanged="dpBirthDate_SelectedDateChanged" />
                        <TextBox x:Name="tbExperience" Grid.Row="3" Margin="0,10,0,0" TextChanged="AnyField_TextChanged" />
                        <TextBox x:Name="tbLogin" Grid.Row="4" Margin="0,10,0,0" TextChanged="tbLogin_TextChanged" />
                        <PasswordBox x:Name="pbPassword" Grid.Row="5" Margin="0,10,0,0" PasswordChanged="PasswordChanged" />
                        <PasswordBox x:Name="pbConfirmPassword" Grid.Row="6" Margin="0,10,0,0" PasswordChanged="PasswordChanged" />
                        <TextBox x:Name="tbEmail" Grid.Row="7" Margin="0,10,0,0" TextChanged="AnyField_TextChanged" />
                        <TextBox x:Name="tbPhone" Grid.Row="8" Margin="0,10,0,0" TextChanged="AnyField_TextChanged" />

                        <Button x:Name="btnRegister" Grid.Row="9" Margin="0,12,0,0" Height="38" Content="Зарегистрироваться" Click="btnRegister_Click" IsEnabled="False" />
                        <Button x:Name="btnBack" Grid.Row="10" Margin="0,8,0,0" Height="38" Background="#157BC8" Content="Назад" Click="btnBack_Click" />

                        <TextBlock x:Name="tbStatus" Grid.Row="11" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#0A4C81" />
                        <TextBlock x:Name="tbLoginHint" Grid.Row="12" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#0A4C81" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
