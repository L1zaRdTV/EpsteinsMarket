<Page x:Class="EpsteinsMarket.Pages.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reg">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="4,0,0,14">
            <TextBlock Text="Создание аккаунта" FontSize="34" FontWeight="Bold"/>
            <TextBlock Text="Заполните данные и получите доступ к каталогу." Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" MaxWidth="860" HorizontalAlignment="Center">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ФИО" Margin="0,0,10,4"/>
                    <TextBlock Grid.Column="1" Text="Дата рождения" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbUserName" Grid.Row="1" Margin="0,0,10,12" TextChanged="AnyField_TextChanged"/>
                    <DatePicker x:Name="dpBirthDate" Grid.Column="1" Grid.Row="1" Margin="0,0,0,12" SelectedDateChanged="dpBirthDate_SelectedDateChanged"/>

                    <TextBlock Grid.Row="2" Text="Опыт работы (лет)" Margin="0,0,10,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Логин" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbExperience" Grid.Row="3" Margin="0,0,10,12" TextChanged="AnyField_TextChanged"/>
                    <TextBox x:Name="tbLogin" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" TextChanged="tbLogin_TextChanged"/>

                    <TextBlock Grid.Row="4" Text="Пароль" Margin="0,0,10,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Подтверждение пароля" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="pbPassword" Grid.Row="5" Margin="0,0,10,12" PasswordChanged="PasswordChanged"/>
                    <PasswordBox x:Name="pbConfirmPassword" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12" PasswordChanged="PasswordChanged"/>

                    <TextBlock Grid.Row="6" Text="Email" Margin="0,0,10,4"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="Телефон" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbEmail" Grid.Row="7" Margin="0,0,10,14" TextChanged="AnyField_TextChanged"/>
                    <TextBox x:Name="tbPhone" Grid.Row="7" Grid.Column="1" Margin="0,0,0,14" TextChanged="AnyField_TextChanged"/>

                    <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="btnRegister" Width="220" Height="40" Content="Зарегистрироваться" Click="btnRegister_Click" IsEnabled="False"/>
                        <Button x:Name="btnBack" Width="140" Height="40" Margin="10,0,0,0" Content="Назад" Style="{StaticResource GhostButtonStyle}" Click="btnBack_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="9" Grid.ColumnSpan="2" x:Name="tbStatus" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#B91C1C"/>
                    <TextBlock Grid.Row="10" Grid.ColumnSpan="2" x:Name="tbLoginHint" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
