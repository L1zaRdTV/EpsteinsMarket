<Page x:Class="EpsteinsMarket.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProfilePage">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Личный кабинет" FontSize="31" FontWeight="Bold"/>
                    <TextBlock Text="Избранное, корзина, покупки и управление профилем в отдельной странице."
                               Margin="0,5,0,0"
                               Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Назад в каталог" MinWidth="160" Click="btnBackToCatalog_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Избранное" FontWeight="Bold" FontSize="18"/>
                        <ListBox Grid.Row="1" Margin="0,10,0,0" x:Name="lbFavorites" DisplayMemberPath="Name"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Корзина" FontWeight="Bold" FontSize="18"/>
                        <ListBox Grid.Row="1" Margin="0,10,0,0" x:Name="lbCart" DisplayMemberPath="Name"/>
                        <Button Grid.Row="2" Margin="0,10,0,0" Content="Оформить покупку" Click="btnCheckout_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1.2*"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Покупки" FontWeight="Bold" FontSize="18"/>
                        <ListBox Grid.Row="1" Margin="0,10,0,0" x:Name="lbPurchases" DisplayMemberPath="Name"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Профиль" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="ФИО" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBox x:Name="tbEditName" Margin="0,6,0,0"/>
                            <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBox x:Name="tbEditEmail" Margin="0,6,0,0"/>
                            <TextBlock Text="Телефон" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBox x:Name="tbEditPhone" Margin="0,6,0,0"/>
                            <Button Margin="0,12,0,0" Content="Сохранить профиль" Click="btnSaveProfile_Click"/>

                            <Separator Margin="0,14,0,14"/>

                            <TextBlock Text="Ссылка на публичный профиль" FontWeight="SemiBold"/>
                            <TextBox x:Name="tbProfileLink" Margin="0,6,0,10" IsReadOnly="True" TextWrapping="Wrap"/>
                            <Border Height="200" BorderThickness="1" BorderBrush="#C5D4CC" CornerRadius="8" Background="#F4F8F6" Padding="8">
                                <Image x:Name="imgQrCode" Stretch="Uniform"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
